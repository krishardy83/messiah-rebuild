---
import Sidebar from "../components/sidebar.astro";
import WithoutHero from "../layouts/without-hero.astro";

const sidebarLinks = [
  {
    title: "Web Services",
    children: [
      { href: "/", name: "FAQ's" },
      { href: "/", name: "Project planning" },
      { href: "/", name: "Services provided" },
      { href: "/", name: "Support & training" },
      { href: "/", name: "Website governance" },
    ],
  },
  {
    title: "Quick Links",
    children: [
      { href: "/", name: "Sign up for training" },
      { href: "/", name: "Request access to edit site" },
    ],
  },
];
---

<WithoutHero
  title="Program page marketing assets"
  description="Program page marketing assets"
  breadcrumbs={[
    { name: "Home", href: "/" },
    { name: "Academics", href: "/" },
    { name: "Using blocks on academic program pages", href: "/" },
  ]}
>
  <Sidebar links={sidebarLinks} slot="sidebar">
    <a href="/" class="btn-tertiary w-full">Submit a web services ticket</a>
  </Sidebar>

  <div
    x-data="{
      programs: [],
      loading: false,
      error: null,
      department: '',
      fields: {
        department_name: true,
        interest_group_name: false,
        keywords: false,
        program_peek: false,
        banner_desk: false,
        banner_mobile: false,
        peek_thumb: false,
        thumbnail_small: false,
      },

      init() {
        this.loading = true;

        fetch('https://www.messiah.edu/_program_data/ug-img-json.json')
          .then((res) => res.json())
          .then((data) => {
            this.programs = data.items;
          })
          .catch((err) => {
            this.error = err.message;
          })
          .finally(() => {
            this.loading = false;
          });
      },

      get departments() {
        const set = new Set(this.programs.map((p) => p.department_name));
        return Array.from(set).sort();
      },

      get filtered() {
        if (!this.department) return [];
        return this.programs.filter((p) => p.department_name === this.department);
      },

      isImage(key) {
        return ['banner_desk', 'banner_mobile', 'peek_thumb', 'thumbnail_small'].includes(key);
      },

      selectAll() {
        Object.keys(this.fields).forEach((key) => this.fields[key] = true);
      },

      deselectAll() {
        Object.keys(this.fields).forEach((key) => this.fields[key] = false);
      },
    }"
  >
    <form class="bg-gray-100 p-4 mb-8" @submit.prevent>
      <h2 class="font-title text-2xl leading-none mb-4 font-bold">Select the fields you would like to show below:</h2>

      <div class="flex gap-4 mb-2">
        <button type="button" @click="selectAll" class="text-sm underline text-primary-800 hover:no-underline">Select all</button>
        <button type="button" @click="deselectAll" class="text-sm underline text-primary-800 hover:no-underline">Deselect all</button>
      </div>

      <div class="grid grid-cols-4 gap-2">
        <label class="flex items-center gap-2">
          <input type="checkbox" x-model="fields.department_name" />
          Department name
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" x-model="fields.interest_group_name" />
          Interest groups
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" x-model="fields.keywords" />
          Keywords
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" x-model="fields.program_peek" />
          Program peek
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" x-model="fields.banner_desk" />
          Desktop hero
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" x-model="fields.banner_mobile" />
          Mobile hero
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" x-model="fields.peek_thumb" />
          Peek image
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" x-model="fields.thumbnail_small" />
          Thumbnail image
        </label>
      </div>

      <select x-model="department" class="bg-white w-1/2 border border-gray-300 block p-2 mt-4 select">
        <option value="">Select a department</option>
        <template x-for="dept in departments" :key="dept">
          <option :value="dept" x-text="dept"></option>
        </template>
      </select>
    </form>

    <template x-if="loading">
      <p class="bg-tertiary-100 border border-tertiary-200 text-tertiary-800 px-4 py-2" role="alert">Loading program data...</p>
    </template>

    <template x-if="error">
      <p class="text-red-600 border border-red-200 bg-red-50 py-2 px-4" role="alert">Failed to load data: <span x-text="error"></span></p>
    </template>

    <template x-if="!loading && !error && !department">
      <p class="py-4 text-gray-500">Select a department to display entries.</p>
    </template>

    <template x-if="!loading && !error && department && filtered.length === 0">
      <p class="py-4 text-gray-500">No entries found for this department.</p>
    </template>

    <div x-show="filtered.length > 0" class="mt-6 space-y-6">
      <template x-for="program in filtered" :key="program.entry_id">
        <div class="border border-gray-200 bg-white p-4">
          <h3 class="font-title text-2xl font-bold text-primary-800 mb-2" x-text="program.program_name"></h3>

          <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm">
            <template x-if="fields.department_name">
              <div class="contents">
                <dt class="font-semibold">Department</dt>
                <dd x-text="program.department_name"></dd>
              </div>
            </template>

            <template x-if="fields.interest_group_name">
              <div class="contents">
                <dt class="font-semibold">Interest Groups</dt>
                <dd x-text="program.interest_group_name"></dd>
              </div>
            </template>

            <template x-if="fields.keywords">
              <div class="contents">
                <dt class="font-semibold">Keywords</dt>
                <dd x-text="program.keywords"></dd>
              </div>
            </template>

            <template x-if="fields.program_peek">
              <div class="contents">
                <dt class="font-semibold">Program Peek</dt>
                <dd x-text="program.program_peek"></dd>
              </div>
            </template>

            <template x-if="fields.banner_desk">
              <div class="col-span-2">
                <p class="font-semibold mb-1">Desktop Hero</p>
                <img :src="program.banner_desk" :alt="program.program_name + ' desktop hero'" class="max-w-full h-auto border border-gray-200" loading="lazy" decoding="async" />
              </div>
            </template>

            <template x-if="fields.banner_mobile">
              <div class="col-span-2">
                <p class="font-semibold mb-1">Mobile Hero</p>
                <img :src="program.banner_mobile" :alt="program.program_name + ' mobile hero'" class="max-w-xs h-auto border border-gray-200" loading="lazy" decoding="async" />
              </div>
            </template>

            <template x-if="fields.peek_thumb">
              <div class="col-span-2">
                <p class="font-semibold mb-1">Peek Image</p>
                <img :src="program.peek_thumb" :alt="program.program_name + ' peek'" class="max-w-xs h-auto border border-gray-200" loading="lazy" decoding="async" />
              </div>
            </template>

            <template x-if="fields.thumbnail_small">
              <div class="col-span-2">
                <p class="font-semibold mb-1">Thumbnail Image</p>
                <img :src="program.thumbnail_small" :alt="program.thumbnail_small_alt" class="max-w-xs h-auto border border-gray-200" loading="lazy" decoding="async" />
              </div>
            </template>
          </dl>
        </div>
      </template>
    </div>
  </div>
</WithoutHero>
