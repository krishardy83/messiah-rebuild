---
import Icon from "../../components/icon.astro";
---

<template x-teleport="body">
  <div
    x-show="savedProgramsDrawerOpen"
    style="display: none"
    x-on:keydown.escape.prevent.stop="savedProgramsDrawerOpen = false"
    role="dialog"
    aria-modal="true"
    x-id="['saved-programs-title']"
    :aria-labelledby="$id('saved-programs-title')"
    class="dialog"
  >
    <div
      x-show="savedProgramsDrawerOpen"
      @click="savedProgramsDrawerOpen = false"
      x-transition.opacity.duration.300
      class="fixed inset-0 bg-primary-800/80 z-50"
    >
    </div>

    <div
      x-show="savedProgramsDrawerOpen"
      x-transition.opacity.duration.300
      x-trap.noscroll.inert="savedProgramsDrawerOpen"
      class="fixed top-0 right-0 bottom-0 w-full sm:max-w-3xl bg-white z-50 overflow-y-auto"
    >
      <div class="flex justify-end p-4">
        <button type="button" @click="savedProgramsDrawerOpen = false" aria-label="Close saved programs drawer">
          <Icon name="close" class="size-10" />
        </button>
      </div>

      <div class="px-4 pb-8">
        <h4 :id="$id('saved-programs-title')" class="h3 mb-6">
          You have <span x-text="bookmarksCount"></span> saved programs
        </h4>

        <template x-if="bookmarkedPrograms.length === 0">
          <p class="bg-tertiary-100 border border-tertiary-200 text-tertiary-800 px-4 py-2">
            You have not bookmarked any programs yet. Use the bookmark button on a program card to save it here.
          </p>
        </template>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8" x-show="bookmarkedPrograms.length > 0">
          <template x-for="program in bookmarkedPrograms" :key="`saved-${program.entry_id}`">
            <article class="flex flex-col border border-gray-300 hover:bg-gray-100 transition-colors relative">
              <img :src="program.thumbnail_small" :alt="program.thumbnail_small_alt" class="w-full aspect-[16/7] object-cover bg-gray-100" loading="lazy" decoding="async" width="352" height="196" />

              <button
                type="button"
                @click="toggleBookmark(program)"
                class="absolute top-4 right-4 size-10 flex items-center justify-center"
                :title="isBookmarked(program) ? 'Remove from bookmarks' : 'Add to bookmarks'"
                :class="isBookmarked(program) ? 'bg-primary-800 text-white border-primary-800' : 'bg-white text-primary-800 hover:bg-gray-100'"
              >
                <Icon name="bookmark" class="size-6" :class="isBookmarked(program) ? 'hidden' : 'block'" />
                <Icon name="bookmark-slash" class="size-6" :class="isBookmarked(program) ? 'block' : 'hidden'" />
              </button>

              <button
                type="button"
                @click="open = program"
                title="View program details"
                class="absolute top-4 right-16 size-10 flex items-center justify-center bg-white text-primary-800 hover:bg-gray-100 focus-visible:bg-gray-100 transition-colors"
              >
                <Icon name="expand" class="size-6" />
              </button>

              <div class="p-4 flex-1 flex flex-col">
                <h5 class="text-primary-800 font-title text-2xl leading-none mb-2">
                  <a :href="getProgramURL(program)" class="text-left hover:underline cursor-pointer" x-text="program.program_name"></a>
                </h5>

                <ol class="inline-flex gap-2 mb-6" x-show="getProgramDegrees(program).length > 0">
                  <template x-for="degree in getProgramDegrees(program)">
                    <li
                      x-text="degree"
                      class="px-1 bg-gray-200 rounded-md uppercase border border-gray-300 text-sm list-item"
                    >
                    </li>
                  </template>
                </ol>

                <ul class="flex gap-2 flex-wrap mt-auto">
                  <template x-for="[key, type] in Object.entries(types)">
                    <li
                      x-show="hasType(program, key)"
                      x-text="type.label"
                      class="text-white text-xs px-2 py-1 rounded-full"
                      :style="`background-color: ${type.color}`"
                    >
                    </li>
                  </template>
                </ul>
              </div>
            </article>
          </template>
        </div>

        <template x-if="bookmarkedRelatedPrograms.length > 0">
          <h4 class="mt-16 mb-6 h3">
            Based on your saved programs, we think you might be interested in the following programs:
          </h4>
        </template>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8" x-show="bookmarkedRelatedPrograms.length > 0">
          <template x-for="program in bookmarkedRelatedPrograms" :key="`saved-related-${program.entry_id}`">
            <article class="flex flex-col border border-gray-300 hover:bg-gray-100 transition-colors relative">
              <img :src="program.thumbnail_small" :alt="program.thumbnail_small_alt" class="w-full aspect-[16/7] object-cover bg-gray-100" loading="lazy" decoding="async" width="352" height="196" />

              <button
                type="button"
                @click="toggleBookmark(program)"
                class="absolute top-4 right-4 size-10 flex items-center justify-center"
                :title="isBookmarked(program) ? 'Remove from bookmarks' : 'Add to bookmarks'"
                :class="isBookmarked(program) ? 'bg-primary-800 text-white border-primary-800' : 'bg-white text-primary-800 hover:bg-gray-100'"
              >
                <Icon name="bookmark" class="size-6" :class="isBookmarked(program) ? 'hidden' : 'block'" />
                <Icon name="bookmark-slash" class="size-6" :class="isBookmarked(program) ? 'block' : 'hidden'" />
              </button>

              <button
                type="button"
                @click="open = program"
                title="View program details"
                class="absolute top-4 right-16 size-10 flex items-center justify-center bg-white text-primary-800 hover:bg-gray-100 focus-visible:bg-gray-100 transition-colors"
              >
                <Icon name="expand" class="size-6" />
              </button>

              <div class="p-4 flex-1 flex flex-col">
                <h5 class="text-primary-800 font-title text-2xl leading-none mb-2">
                  <a :href="getProgramURL(program)" class="text-left hover:underline cursor-pointer" x-text="program.program_name"></a>
                </h5>

                <ol class="inline-flex gap-2 mb-6" x-show="getProgramDegrees(program).length > 0">
                  <template x-for="degree in getProgramDegrees(program)">
                    <li
                      x-text="degree"
                      class="px-1 bg-gray-200 rounded-md uppercase border border-gray-300 text-sm list-item"
                    >
                    </li>
                  </template>
                </ol>

                <ul class="flex gap-2 flex-wrap mt-auto">
                  <template x-for="[key, type] in Object.entries(types)">
                    <li
                      x-show="hasType(program, key)"
                      x-text="type.label"
                      class="text-white text-xs px-2 py-1 rounded-full"
                      :style="`background-color: ${type.color}`"
                    >
                    </li>
                  </template>
                </ul>
              </div>
            </article>
          </template>
        </div>
      </div>
    </div>
  </div>
</template>
