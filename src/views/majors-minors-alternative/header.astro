<header
  class="relative bg-[image:var(--bg-banner)] isolate bg-center pt-24 bg-cover bg-no-repeat after:absolute after:inset-0 after:bg-gradient-to-b after:from-black/60 after:to-transparent -mt-32 before:absolute before:inset-0 before:bg-gradient-to-r before:from-primary-700/60 before:to-transparent"
  style={{
    "--bg-banner": "url(https://www.messiah.edu/undergraduate/interest-area/science-health-the-natural-world/_images/science.webp)",
  }}
  aria-hidden="true"
>
  <div
    class="mx-auto max-w-6xl px-4 h-[60vh] min-h-[450px] max-h-[800px] flex flex-col justify-center text-center relative z-10 text-white"
  >
    <h1 class="font-title text-5xl lg:text-6xl xl:text-8xl font-bold mb-2">
      Undergraduate Programs
    </h1>
    <p class="font-title text-xl lg:text-3xl">
      Full list of majors, minors, and programs at Messiah University
    </p>

    <nav class="flex gap-2 bg-white p-2 rounded-full w-max mx-auto mt-12">
      <button
        type="button"
        @click="setView('az')"
        :class="view === 'az' ? 'text-white bg-primary-800 hover:bg-primary-700' : 'text-primary-800 hover:bg-gray-100'"
        class="px-4 py-2 rounded-full min-w-24 transition-colors"
      >
        A-Z
      </button>
      <button
        type="button"
        @click="setView('interest')"
        :class="view === 'interest' ? 'text-white bg-primary-800 hover:bg-primary-700' : 'text-primary-800 hover:bg-gray-100'"
        class="px-4 py-2 rounded-full min-w-24 transition-colors"
      >
        Browse by Interest
      </button>
    </nav>
  </div>
</header>