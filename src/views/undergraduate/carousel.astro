---
import Icon from "../../components/icon.astro";
---

<div
  class="wrapper mx-auto border-t border-gray-200 mt-12 pt-12"
  x-data="{
    embla: null,
    index: 0,
    canScrollPrev: false,
    canScrollNext: false,

    init() {
      this.embla = EmblaCarousel(this.$refs.embla, {
        align: 'start',
        containScroll: 'trimSnaps',
      });

      this.updateScrollState();

      this.embla.on('select', (api) => {
        this.index = api.selectedScrollSnap();
        this.updateScrollState();
      });

      this.embla.on('resize', () => {
        this.updateScrollState();
      });
    },

    updateScrollState() {
      this.canScrollPrev = this.embla.canScrollPrev();
      this.canScrollNext = this.embla.canScrollNext();
    },

    scrollNext() {
      this.embla.scrollNext();
    },

    scrollPrev() {
      this.embla.scrollPrev();
    },
}"
>
  <div
    class="overflow-hidden relative"
    x-ref="embla"
  >
    <div class="flex touch-pan-y">
      
      <div class="basis-full sm:basis-1/2 lg:basis-1/3 flex-shrink-0 flex-grow-0 px-4 flex justify-center sm:justify-start">
        <div class="flex gap-3">
          <div>
            <span class="font-bold text-2xl block">100%</span>
            <img src="/graphics/home/fin-aid.svg" alt="" width="60" role="presentation" />
          </div>
          <div class="font-title text-3xl">
            of first-year<br />students receive <span
              class="text-tertiary-400 uppercase block font-semibold">financial aid</span
            >
          </div>
        </div>
      </div>

      <div class="basis-full sm:basis-1/2 lg:basis-1/3 flex-shrink-0 flex-grow-0 px-4 flex justify-center sm:justify-start">
        <div class="flex gap-3">
          <div class="relative shrink-0">
            <span class="font-bold text-3xl block text-white absolute top-8 left-6">96%</span>
            <img src="/graphics/home/employed.svg" alt="" width="106" role="presentation" />
          </div>
          <div class="font-title text-lg leading-none">
            of the class of 2022 were<br />
            <span class="text-tertiary-400 font-bold block text-3xl">employed</span>
            or in a <span class="text-tertiary-400 font-bold">graduate program</span><br />
            <span class="text-base italic">within 6 - 9 months after graduation</span>
          </div>
        </div>
      </div>

      <div class="basis-full sm:basis-1/2 lg:basis-1/3 flex-shrink-0 flex-grow-0 px-4 flex justify-center sm:justify-start">
        <div class="font-title font-bold text-primary-800">
          <div class="flex gap-2 -mb-2">
            <span class="text-8xl">12:1</span>
            <img src="/graphics/home/faculty.svg" alt="" width="100" role="presentation" />
          </div>
          <span class="text-xl text-primary-800">student to faculty ratio</span>
        </div>
      </div>

      <div class="basis-full sm:basis-1/2 lg:basis-1/3 flex-shrink-0 flex-grow-0 px-4 flex justify-center sm:justify-start">
        <div class="font-title font-bold text-primary-800">
          <div class="flex gap-2 -mb-2">
            <span class="text-8xl">12:1</span>
            <img src="/graphics/home/faculty.svg" alt="" width="100" role="presentation" />
          </div>
          <span class="text-xl text-primary-800">student to faculty ratio</span>
        </div>
      </div>
        
    </div>

    <button
      type="button"
      class="absolute top-1/2 -translate-y-1/2 text-gray-700 left-0 z-20 transition-opacity duration-300 h-full bg-gradient-to-l from-transparent to-white"
      x-show="canScrollPrev"
      aria-label="Previous slide"
      @click="scrollPrev"
    >
      <Icon name="chevron-right" class="size-10 rotate-180" />
    </button>
    <button
      type="button"
      class="absolute top-1/2 -translate-y-1/2 text-gray-700 right-0 z-20 transition-opacity duration-300 h-full bg-gradient-to-r from-transparent to-white"
      x-show="canScrollNext"
      aria-label="Next slide"
      @click="scrollNext"
    >
      <Icon name="chevron-right" class="size-10" />
    </button>
  </div>
</div>